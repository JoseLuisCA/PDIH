basico <- readWave("basico.wav")
x <- basico@left
sr <- basico@samp.rate
delay <- round(0.3 * sr)
eco_signal <- x
# añadimos eco atenuado y retrasado
eco_signal[(delay + 1):(length(x))] <- eco_signal[(delay + 1):(length(x))] +
x[1:(length(x) - delay)] * 0.6
basico <- readWave("basico.wav")
x <- basico@left
sr <- basico@samp.rate
delay <- round(0.3 * sr)
eco_signal <- x
eco_signal[(delay + 1):(length(x))] <- eco_signal[(delay + 1):(length(x))] +
x[1:(length(x) - delay)] * 0.6
eco <- Wave(
left = as.integer(eco_signal),
samp.rate = sr,
bit = basico@bit
)
eco@left <- eco@left / max(abs(eco@left)) * (2^(eco@bit - 1) - 1)
writeWave(eco, "eco.wav")
