)
listen(eco, f = eco@samp.rate)
delay <- round(0.3 * basico@samp.rate)
eco_signal <- c(
basico@left,
rep(0, delay),
basico@left * 0.6
)
eco <- Wave(
left = as.integer(eco_signal[1:length(basico@left)]),
samp.rate = basico@samp.rate,
bit = basico@bit
)
eco@left <- eco@left / max(abs(eco@left)) * (2^(eco@bit - 1) - 1)
listen(eco, f = eco@samp.rate)
